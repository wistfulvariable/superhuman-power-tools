{
  "manifest_version": 3,
  "name": "Superhuman Power Tools",
  "version": "2.1",
  "description": "Auto-clicks SEND ANYWAY popups, Gmail filter creation, and AI email summarization for Superhuman",
  "permissions": ["activeTab", "storage"],
  "host_permissions": ["https://api.anthropic.com/*"],
  "commands": {
    "create-filter": {
      "suggested_key": {
        "default": "Alt+G"
      },
      "description": "Create Gmail filter from current email"
    }
  },
  "action": {
    "default_title": "Superhuman Power Tools",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://mail.superhuman.com/*"],
      "js": ["content.js"]
    },
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["gmail-content.js"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
